+import React, { useState } from 'react';
+import { View, TextInput, Pressable, Text, FlatList } from 'react-native';
+import { Audio } from 'expo-av';
+import { useApp } from '@/context/AppContext';
+import { Bubble } from '@/components/Bubble';
+
+export default function ChatRoomScreen({ route }: any) {
+  const { chatId } = route.params;
+  const { currentUser, messages, sendMessage } = useApp();
+  const [text, setText] = useState('');
+
+  const onSend = () => {
+    if (!currentUser || !text.trim()) return;
+    sendMessage(chatId, { senderId: currentUser.id, text });
+    setText('');
+  };
+
+  const fakeVoiceNote = async () => {
+    await Audio.requestPermissionsAsync();
+    if (!currentUser) return;
+    sendMessage(chatId, { senderId: currentUser.id, voiceUri: 'local://voice-note.m4a' });
+  };
+
+  return (
+    <View style={{ flex: 1, backgroundColor: '#050505', padding: 12 }}>
+      <FlatList data={messages[chatId] || []} keyExtractor={(m) => m.id} renderItem={({ item }) => <Bubble message={item} mine={item.senderId === currentUser?.id} />} />
+      <View style={{ flexDirection: 'row', gap: 8 }}>
+        <TextInput value={text} onChangeText={setText} placeholder='Type message' placeholderTextColor='#777' style={{ flex: 1, backgroundColor: '#131313', color: '#eee', borderRadius: 18, paddingHorizontal: 14 }} />
+        <Pressable onPress={fakeVoiceNote} style={{ backgroundColor: '#222', borderRadius: 18, padding: 12 }}><Text style={{ color: '#ddd' }}>🎤</Text></Pressable>
+        <Pressable onPress={onSend} style={{ backgroundColor: '#ddd', borderRadius: 18, padding: 12 }}><Text>Send</Text></Pressable>
+      </View>
+    </View>
+  );
+}
