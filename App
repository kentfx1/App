@@ -0,0 +1,53 @@
+import React, { createContext, useContext, useMemo, useState } from 'react';
+import { Chat, Message, User } from '@/types';
+
+type AppState = {
+  currentUser?: User;
+  users: User[];
+  chats: Chat[];
+  messages: Record<string, Message[]>;
+  setCurrentUser: (u?: User) => void;
+  sendMessage: (chatId: string, payload: Omit<Message, 'id' | 'createdAt' | 'readBy'>) => void;
+  markRead: (chatId: string, userId: string) => void;
+};
+
+const initialUsers: User[] = [
+  { id: 'u1', username: 'Nova', isOnline: true },
+  { id: 'u2', username: 'LuxeWolf', isOnline: true },
+  { id: 'u3', username: 'Astra', isOnline: false }
+];
+
+const AppContext = createContext<AppState | null>(null);
+
+export function AppProvider({ children }: { children: React.ReactNode }) {
+  const [currentUser, setCurrentUser] = useState<User>();
+  const [users] = useState(initialUsers);
+  const [chats] = useState<Chat[]>([{ id: 'c1', title: 'Nova & LuxeWolf', participantIds: ['u1', 'u2'] }]);
+  const [messages, setMessages] = useState<Record<string, Message[]>>({ c1: [] });
+
+  const sendMessage: AppState['sendMessage'] = (chatId, payload) => {
+    setMessages((prev) => ({
+      ...prev,
+      [chatId]: [
+        ...(prev[chatId] ?? []),
+        { ...payload, id: Math.random().toString(36), createdAt: Date.now(), readBy: [payload.senderId] }
+      ]
+    }));
+  };
+
+  const markRead = (chatId: string, userId: string) => {
+    setMessages((prev) => ({
+      ...prev,
+      [chatId]: (prev[chatId] ?? []).map((m) => ({ ...m, readBy: m.readBy.includes(userId) ? m.readBy : [...m.readBy, userId] }))
+    }));
+  };
+
+  const value = useMemo(() => ({ currentUser, users, chats, messages, setCurrentUser, sendMessage, markRead }), [currentUser, users, chats, messages]);
+  return <AppContext.Provider value={value}>{children}</AppContext.Provider>;
+}
+
+export function useApp() {
+  const ctx = useContext(AppContext);
+  if (!ctx) throw new Error('useApp must be used within AppProvider');
+  return ctx;
+}
